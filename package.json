{
  "name": "@brinzl/filediff",
  "version": "0.1.0",
  "type": "module",
  "description": "A browser-based git diff viewer",
  "author": "Brinsil Elias",
  "files": [
    "dist"
  ],
  "bin": {
    "filediff": "dist/filediff.js"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "bun --watch bin/filediff.ts",
    "build": "tsc && vite build && vite build --ssr bin/filediff.ts --outDir dist",
    "preview": "bun dist/filediff.js"
  },
  "//": [
    "All dependencies are devDependencies because the React app is",
    "prebuilt into static files and served by the server.",
    "Nothing is needed at runtime."
  ],
  "devDependencies": {
    "@pierre/diffs": "^1.0.11",
    "@react-symbols/icons": "^1.3.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.576.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "homepage": "https://github.com/brinzl/filediff#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brinzl/filediff.git"
  },
  "bugs": {
    "url": "https://github.com/brinzl/filediff/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
